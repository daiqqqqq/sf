COMPOSE_PROJECT_NAME=rag-platform
TZ=Asia/Shanghai

APP_HOST=192.168.110.117
APP_PORT=80
API_PORT=8000
RAG_PORT=8100
OPS_PORT=8200
RERANKER_PORT=8300
STARTUP_TIMEOUT_SECONDS=180
STARTUP_POLL_INTERVAL_SECONDS=2
HEALTH_SNAPSHOT_KEEP_PER_SERVICE=20
MAX_UPLOAD_BYTES=268435456
API_WORKERS=2
RAG_WORKERS=2
CELERY_WORKER_CONCURRENCY=2

ADMIN_USERNAME=admin
ADMIN_PASSWORD=ChangeMeNow_123
JWT_SECRET=please-change-this-jwt-secret
INTERNAL_SERVICE_TOKEN=please-change-this-internal-token
OPS_AGENT_TOKEN=please-change-this-ops-agent-token

DATABASE_URL=postgresql+psycopg://rag_platform:rag_platform@postgres:5432/rag_platform
POSTGRES_DB=rag_platform
POSTGRES_USER=rag_platform
POSTGRES_PASSWORD=rag_platform

REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2
TASK_EXECUTION_MODE=celery

KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_TOPIC_INGEST=rag-ingest
KAFKA_TOPIC_AUDIT=rag-audit

MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET=rag-documents
MINIO_SECURE=false

ELASTICSEARCH_URL=http://elasticsearch:9200
ELASTICSEARCH_INDEX=rag-documents
ES_JAVA_OPTS=-Xms2g -Xmx2g

MILVUS_URI=http://milvus:19530
MILVUS_COLLECTION=rag_chunks
MILVUS_TOKEN=

TIKA_URL=http://tika:9998
RERANKER_URL=http://reranker:8300
RAG_ENGINE_URL=http://rag-engine:8100
OPS_AGENT_URL=http://ops-agent:8200

OLLAMA_BASE_URL=http://192.168.110.241:11434
OLLAMA_EMBEDDING_MODEL=qwen3-embedding:latest
VLLM_QWEN27_BASE_URL=http://192.168.110.241:12434/v1
VLLM_QWEN27_API_KEY=qwen-241-12434
VLLM_QWEN27_MODEL=qwen3.5-27b-int8-128k
VLLM_QWEN35_BASE_URL=http://192.168.110.241:13434/v1
VLLM_QWEN35_API_KEY=qwen-241-13434
VLLM_QWEN35_MODEL=qwen3.5-35b-a3b-int4-256k

DOCKER_COMPOSE_FILE=/workspace/deploy/two-server/app-node/docker-compose.yml
DOCKER_ALLOWED_SERVICES=nginx,dashboard-web,platform-api,rag-engine,reranker,celery-worker,celery-beat,redis,kafka,minio,postgres,elasticsearch,milvus,tika

PERSIST_ROOT=/opt/rag-platform
APP_DATA_ROOT=/opt/rag-platform/data

